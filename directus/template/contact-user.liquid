<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>We received your message</title>
  </head>
  <body style="margin:0;padding:0;background-color:#f4f5f7;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f5f7;padding:32px 16px;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">
            <!-- Header -->
            <tr>
              <td style="background-color:#0F1225;border-radius:12px 12px 0 0;padding:28px 40px;">
                <img src="https://admin.codeanew.com/assets/0cc9a222-91f6-4aa7-89d2-eb2d95d2dc35.png" alt="Codeanew" height="36" style="display:block;">
              </td>
            </tr>

            <!-- Accent bar -->
            <tr>
              <td style="background-color:#F5A623;height:3px;font-size:0;line-height:0;">&nbsp;</td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="background-color:#ffffff;padding:40px 40px 32px;">
                <h1 style="margin:0 0 20px;font-size:22px;font-weight:700;color:#0F1225;line-height:1.3;">
                  Hi {{ fullname }},
                </h1>
                <p style="margin:0 0 16px;font-size:15px;color:#4b5563;line-height:1.8;">
                  Thank you for reaching out to <strong style="color:#0F1225;">Codeanew</strong>. We've received your
                  message and one of our team members will get back to you within
                  <strong style="color:#0F1225;">1–2 business days</strong>.
                </p>
                <p style="margin:0 0 32px;font-size:15px;color:#4b5563;line-height:1.8;">
                  In the meantime, feel free to explore our work and see how we've helped businesses grow digitally.
                </p>

                <!-- CTA -->
                <table cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="border-radius:6px;">
                      <a
                        href="https://codeanew.com"
                        style="display:inline-block;background-color:#F5A623;color:#0F1225;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:0.05em;padding:13px 32px;border-radius:6px;"
                        >Visit our website &rarr;</a
                      >
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Divider -->
            <tr>
              <td style="background-color:#ffffff;padding:0 40px;">
                <hr style="border:none;border-top:1px solid #f0f1f3;margin:0;">
              </td>
            </tr>

            <!-- Sign-off -->
            <tr>
              <td style="background-color:#ffffff;padding:24px 40px 36px;">
                <p style="margin:0 0 2px;font-size:14px;color:#4b5563;">Best regards,</p>
                <p style="margin:0;font-size:15px;font-weight:700;color:#0F1225;">The Codeanew Team</p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color:#0F1225;border-radius:0 0 12px 12px;padding:28px 40px;">
                <!-- Social icons -->
                <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom:18px;">
                  <tr>
                    <!-- Instagram -->
                    <td style="padding-right:10px;">
                      <a href="https://www.instagram.com/codeanew/" style="display:inline-block;text-decoration:none;">
                        <table cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td style="background-color:#4867aa;border-radius:8px;width:36px;height:36px;text-align:center;vertical-align:middle;">
                              <img
                                src="https://img.icons8.com/ios-filled/20/ffffff/instagram-new.png"
                                alt="Instagram"
                                width="20"
                                height="20"
                                style="display:block;margin:8px auto;"
                              >
                            </td>
                          </tr>
                        </table>
                      </a>
                    </td>
                    <!-- LinkedIn -->
                    <td>
                      <a
                        href="https://www.linkedin.com/company/codeanew/"
                        style="display:inline-block;text-decoration:none;"
                      >
                        <table cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td style="background-color:#1c82ca;border-radius:8px;width:36px;height:36px;text-align:center;vertical-align:middle;">
                              <img
                                src="https://img.icons8.com/ios-filled/20/ffffff/linkedin.png"
                                alt="LinkedIn"
                                width="20"
                                height="20"
                                style="display:block;margin:8px auto;"
                              >
                            </td>
                          </tr>
                        </table>
                      </a>
                    </td>
                  </tr>
                </table>

                <!-- Contact -->
                <p style="margin:0 0 4px;font-size:12px;color:#9ca3af;">
                  <a href="tel:+971504264650" style="color:#9ca3af;text-decoration:none;">+971 50 426 4650</a>
                  &nbsp;&middot;&nbsp;
                  <a href="mailto:info@codeanew.com" style="color:#9ca3af;text-decoration:none;">info@codeanew.com</a>
                </p>

                <!-- Copyright -->
                <p style="margin:12px 0 0;font-size:11px;color:#6b7280;">&copy; {{year}} Codeanew. All rights reserved.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
