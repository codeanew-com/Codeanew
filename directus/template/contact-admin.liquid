<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Contact Form Submission</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f5f7;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f5f7;padding:32px 16px;">
  <tr>
    <td align="center">
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        <!-- Header -->
        <tr>
          <td style="background-color:#0F1225;border-radius:12px 12px 0 0;padding:28px 40px;">
            <img src="data:image/png;base64," alt="Codeanew" height="36" style="display:block;">
          </td>
        </tr>

        <!-- Accent bar -->
        <tr>
          <td style="background-color:#F5A623;height:3px;font-size:0;line-height:0;">&nbsp;</td>
        </tr>

        <!-- Title -->
        <tr>
          <td style="background-color:#ffffff;padding:32px 40px 20px;">
            <p style="margin:0 0 4px;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#F5A623;">New Submission</p>
            <h1 style="margin:0;font-size:22px;font-weight:700;color:#0F1225;line-height:1.3;">Contact Form Submission</h1>
          </td>
        </tr>

        <!-- Fields -->
        <tr>
          <td style="background-color:#ffffff;padding:0 40px 8px;">

            <!-- Name -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
              <tr>
                <td style="background-color:#f8f9fb;border-radius:8px;padding:14px 18px;">
                  <p style="margin:0 0 3px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Name</p>
                  <p style="margin:0;font-size:15px;font-weight:600;color:#0F1225;">{{fullname}}</p>
                </td>
              </tr>
            </table>

            <!-- Email + Phone -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
              <tr>
                <td width="49%" style="background-color:#f8f9fb;border-radius:8px;padding:14px 18px;">
                  <p style="margin:0 0 3px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Email</p>
                  <p style="margin:0;font-size:14px;color:#0F1225;">{{email}}</p>
                </td>
                <td width="2%">&nbsp;</td>
                <td width="49%" style="background-color:#f8f9fb;border-radius:8px;padding:14px 18px;">
                  <p style="margin:0 0 3px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Phone</p>
                  <p style="margin:0;font-size:14px;color:#0F1225;">{{phone}}</p>
                </td>
              </tr>
            </table>

            <!-- Service -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
              <tr>
                <td style="background-color:#f8f9fb;border-radius:8px;padding:14px 18px;">
                  <p style="margin:0 0 3px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Service(s)</p>
                  <p style="margin:0;font-size:14px;color:#0F1225;">{{service}}</p>
                </td>
              </tr>
            </table>

            <!-- Budget -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
              <tr>
                <td style="background-color:#fff8ec;border-left:3px solid #F5A623;border-radius:0 8px 8px 0;padding:14px 18px;">
                  <p style="margin:0 0 3px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Budget</p>
                  <p style="margin:0;font-size:15px;font-weight:700;color:#0F1225;">{{budget}}</p>
                </td>
              </tr>
            </table>

            <!-- Message -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
              <tr>
                <td style="background-color:#f8f9fb;border-radius:8px;padding:14px 18px;">
                  <p style="margin:0 0 8px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9aa0b0;">Message</p>
                  <p style="margin:0;font-size:14px;color:#0F1225;line-height:1.7;">{{message}}</p>
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <!-- Reply CTA -->
        <tr>
          <td style="background-color:#ffffff;padding:24px 40px 36px;">
            <a href="mailto:{{email}}" style="display:inline-block;background-color:#F5A623;color:#0F1225;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:0.05em;padding:12px 28px;border-radius:6px;">Reply to {{fullname}}</a>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background-color:#0F1225;border-radius:0 0 12px 12px;padding:24px 40px;">
            <p style="margin:0;font-size:12px;color:#6b7280;line-height:1.7;">
              This is an automated notification from your Codeanew contact form.<br>
              &copy; 2025 Codeanew. All rights reserved.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
